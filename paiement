<!DOCTYPE html>
<html lang="fr">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Paiement WiFi Dagazz</title>

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial,sans-serif;
}

body{
  background:#0b0f14;
  color:white;
  display:flex;
  justify-content:center;
  align-items:center;
  height:100vh;
}

/* ================= CARD ================= */
.box{
  background:#141a22;
  padding:25px;
  border-radius:15px;
  width:90%;
  max-width:400px;
  box-shadow:0 0 20px rgba(0,0,0,0.5);
}

/* ================= HEADER INFO ================= */
.plan{
  font-size:22px;
  font-weight:bold;
  margin-bottom:10px;
}

.price{
  font-size:28px;
  color:#38bdf8;
  margin-bottom:5px;
}

.speed{
  color:#9aa4b2;
  margin-bottom:20px;
}

/* ================= INPUT ================= */
input{
  width:100%;
  padding:12px;
  margin-top:10px;
  border:none;
  border-radius:8px;
  outline:none;
}

/* ================= BUTTON ================= */
button{
  width:100%;
  padding:12px;
  margin-top:15px;
  border:none;
  border-radius:8px;
  background:#2563eb;
  color:white;
  font-weight:bold;
  cursor:pointer;
  transition:0.3s;
}

button:hover{
  transform:scale(1.05);
  background:#1d4ed8;
}

/* ================= BACK ================= */
.back{
  margin-top:15px;
  text-align:center;
}

.back a{
  color:#9aa4b2;
  text-decoration:none;
  font-size:14px;
}

.back a:hover{
  color:white;
}

</style>

</head>

<body>

<div class="box">

  <!-- INFOS ABONNEMENT -->
  <div class="plan" id="plan">Abonnement</div>
  <div class="price" id="prix">0 FCFA</div>
  <div class="speed" id="speed"></div>

  <!-- FORMULAIRE PAIEMENT -->
  <input type="text" placeholder="Numéro Mobile Money">
  <input type="password" placeholder="Code PIN">

  <button>Payer maintenant</button>

  <div class="back">
    <a href="index.html">← Retour aux offres</a>
  </div>

</div>

<!-- ================= SCRIPT ================= -->
<script>

const params = new URLSearchParams(window.location.search);

const plan = params.get("plan");
const prix = params.get("prix");
const speed = params.get("speed");

document.getElementById("plan").textContent = plan || "Abonnement inconnu";
document.getElementById("prix").textContent = (prix || "0") + " FCFA";

if(speed){
  document.getElementById("speed").textContent = "Vitesse : " + speed;
}

</script>

</body>
</html>
